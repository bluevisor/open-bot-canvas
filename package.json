{
  "name": "open-bot-canvas",
  "version": "0.0.0",
  "private": true,
  "description": "AI-grown repository — daily tally bot and supporting infrastructure",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
